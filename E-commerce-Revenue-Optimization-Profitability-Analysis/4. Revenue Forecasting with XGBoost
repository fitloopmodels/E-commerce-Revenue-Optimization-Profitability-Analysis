import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split, TimeSeriesSplit
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score
import xgboost as xgb
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime, timedelta
import warnings
warnings.filterwarnings('ignore')

class RevenueForecaster:
    def __init__(self, data):
        """
        Initialize revenue forecaster
        
        Parameters:
        - data: DataFrame with daily revenue and features
        """
        self.data = data
        self.model = None
        self.feature_importance = None
        self.scaler = StandardScaler()
        
    def create_time_features(self):
        """Create time-based features for forecasting"""
        # Ensure date column exists
        if 'date' not in self.data.columns:
            self.data['date'] = pd.to_datetime(self.data['order_purchase_timestamp']).dt.date
        
        # Group by date
        daily_data = self.data.groupby('date').agg({
            'payment_value': 'sum',
            'order_id': 'count',
            'price': 'mean'
        }).reset_index()
        
        daily_data.columns = ['date', 'daily_revenue', 'order_count', 'avg_order_value']
        daily_data = daily_data.sort_values('date')
        
        # Create time features
        daily_data['day_of_week'] = pd.to_datetime(daily_data['date']).dt.dayofweek
        daily_data['month'] = pd.to_datetime(daily_data['date']).dt.month
        daily_data['quarter'] = pd.to_datetime(daily_data['date']).dt.quarter
        daily_data['day_of_year'] = pd.to_datetime(daily_data['date']).dt.dayofyear
        daily_data['week_of_year'] = pd.to_datetime(daily_data['date']).dt.isocalendar().week
        
        # Add lag features
        for lag in [1, 2, 3, 7, 14, 21, 28]:
            daily_data[f'revenue_lag_{lag}'] = daily_data['daily_revenue'].shift(lag)
            daily_data[f'orders_lag_{lag}'] = daily_data['order_count'].shift(lag)
        
        # Add rolling statistics
        for window in [7, 14, 30]:
            daily_data[f'revenue_rolling_mean_{window}'] = daily_data['daily_revenue'].rolling(window=window).mean()
            daily_data[f'revenue_rolling_std_{window}'] = daily_data['daily_revenue'].rolling(window=window).std()
        
        # Drop NaN values from lag features
        daily_data = daily_data.dropna()
        
        self.daily_data = daily_data
        return daily_data
    
    def prepare_features(self):
        """Prepare features for model training"""
        feature_columns = ['day_of_week', 'month', 'quarter', 'day_of_year', 'week_of_year',
                          'order_count', 'avg_order_value']
        
        # Add lag columns
        feature_columns += [col for col in self.daily_data.columns if 'lag' in col]
        feature_columns += [col for col in self.daily_data.columns if 'rolling' in col]
        
        X = self.daily_data[feature_columns]
        y = self.daily_data['daily_revenue']
        
        # Split data chronologically
        split_date = self.daily_data['date'].quantile(0.8)
        train_mask = self.daily_data['date'] <= split_date
        test_mask = self.daily_data['date'] > split_date
        
        X_train = X[train_mask]
        X_test = X[test_mask]
        y_train = y[train_mask]
        y_test = y[test_mask]
        
        # Scale features
        X_train_scaled = self.scaler.fit_transform(X_train)
        X_test_scaled = self.scaler.transform(X_test)
        
        return X_train_scaled, X_test_scaled, y_train, y_test, X_train.columns
    
    def train_model(self, X_train, y_train):
        """Train XGBoost model"""
        self.model = xgb.XGBRegressor(
            n_estimators=200,
            max_depth=7,
            learning_rate=0.05,
            subsample=0.8,
            colsample_bytree=0.8,
            random_state=42,
            early_stopping_rounds=20,
            eval_metric='rmse'
        )
        
        # Train with validation set
        self.model.fit(
            X_train, y_train,
            eval_set=[(X_train, y_train)],
            verbose=False
        )
        
        return self.model
    
    def evaluate_model(self, X_test, y_test):
        """Evaluate model performance"""
        y_pred = self.model.predict(X_test)
        
        rmse = np.sqrt(mean_squared_error(y_test, y_pred))
        mae = mean_absolute_error(y_test, y_pred)
        r2 = r2_score(y_test, y_pred)
        
        # Baseline model (simple moving average)
        baseline_pred = y_test.rolling(7).mean().fillna(y_test.mean())
        baseline_rmse = np.sqrt(mean_squared_error(y_test, baseline_pred))
        
        rmse_reduction = ((baseline_rmse - rmse) / baseline_rmse) * 100
        
        print(f"Model Performance:")
        print(f"RMSE: ${rmse:.2f}")
        print(f"MAE: ${mae:.2f}")
        print(f"R² Score: {r2:.4f}")
        print(f"Baseline RMSE: ${baseline_rmse:.2f}")
        print(f"RMSE Reduction: {rmse_reduction:.1f}%")
        
        # Feature importance
        self.feature_importance = pd.DataFrame({
            'feature': X_test.columns,
            'importance': self.model.feature_importances_
        }).sort_values('importance', ascending=False)
        
        return {
            'rmse': rmse,
            'mae': mae,
            'r2': r2,
            'rmse_reduction': rmse_reduction,
            'predictions': y_pred,
            'actual': y_test
        }
    
    def plot_results(self, y_test, y_pred):
        """Visualize forecast results"""
        fig, axes = plt.subplots(2, 2, figsize=(15, 10))
        
        # Actual vs Predicted
        axes[0,0].plot(y_test.values, label='Actual', alpha=0.7)
        axes[0,0].plot(y_pred, label='Predicted', alpha=0.7)
        axes[0,0].set_title('Daily Revenue: Actual vs Predicted')
        axes[0,0].set_xlabel('Days')
        axes[0,0].set_ylabel('Revenue ($)')
        axes[0,0].legend()
        
        # Scatter plot
        axes[0,1].scatter(y_test, y_pred, alpha=0.5)
        axes[0,1].plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 'r--', lw=2)
        axes[0,1].set_title('Actual vs Predicted Revenue')
        axes[0,1].set_xlabel('Actual Revenue')
        axes[0,1].set_ylabel('Predicted Revenue')
        
        # Residuals
        residuals = y_test.values - y_pred
        axes[1,0].hist(residuals, bins=30, edgecolor='black')
        axes[1,0].set_title('Residual Distribution')
        axes[1,0].set_xlabel('Residual')
        axes[1,0].set_ylabel('Frequency')
        
        # Feature importance
        top_features = self.feature_importance.head(10)
        axes[1,1].barh(top_features['feature'], top_features['importance'])
        axes[1,1].set_title('Top 10 Feature Importance')
        axes[1,1].set_xlabel('Importance')
        
        plt.tight_layout()
        plt.savefig('reports/revenue_forecast_results.png', dpi=300, bbox_inches='tight')
        plt.show()
        
        return fig
    
    def forecast_future(self, days=30):
        """Forecast future revenue"""
        # Get last available data
        last_date = self.daily_data['date'].max()
        future_dates = [last_date + timedelta(days=i) for i in range(1, days+1)]
        
        # Prepare future features (simplified for demonstration)
        future_data = pd.DataFrame({'date': future_dates})
        future_data['day_of_week'] = pd.to_datetime(future_data['date']).dt.dayofweek
        future_data['month'] = pd.to_datetime(future_data['date']).dt.month
        future_data['quarter'] = pd.to_datetime(future_data['date']).dt.quarter
        future_data['day_of_year'] = pd.to_datetime(future_data['date']).dt.dayofyear
        future_data['week_of_year'] = pd.to_datetime(future_data['date']).dt.isocalendar().week
        
        # Use last known values for other features
        last_known = self.daily_data.iloc[-1]
        for col in self.daily_data.columns:
            if col not in future_data.columns and col != 'date':
                future_data[col] = last_known.get(col, 0)
        
        # Select feature columns
        feature_cols = self.feature_importance['feature'].values
        X_future = future_data[feature_cols]
        
        # Scale features
        X_future_scaled = self.scaler.transform(X_future)
        
        # Predict
        future_revenue = self.model.predict(X_future_scaled)
        
        forecast_df = pd.DataFrame({
            'date': future_dates,
            'forecasted_revenue': future_revenue
        })
        
        return forecast_df

if __name__ == "__main__":
    # Load processed data
    orders_df = pd.read_parquet('data/processed/processed_orders.parquet')
    
    # Initialize forecaster
    forecaster = RevenueForecaster(orders_df)
    
    # Create time features
    daily_data = forecaster.create_time_features()
    
    # Prepare features
    X_train, X_test, y_train, y_test, feature_names = forecaster.prepare_features()
    
    # Train model
    forecaster.train_model(X_train, y_train)
    
    # Evaluate
    results = forecaster.evaluate_model(X_test, y_test)
    
    # Plot results
    forecaster.plot_results(y_test, results['predictions'])
    
    # Forecast future
    future_forecast = forecaster.forecast_future(days=30)
    future_forecast.to_csv('reports/future_revenue_forecast.csv', index=False)
    
    print("\nFuture Revenue Forecast (Next 7 days):")
    print(future_forecast.head(7))