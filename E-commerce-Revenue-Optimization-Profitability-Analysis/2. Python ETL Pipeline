import pandas as pd
import numpy as np
from sqlalchemy import create_engine
import logging
from datetime import datetime
import os

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

class EcommerceETL:
    def __init__(self, data_path='data/raw/', output_path='data/processed/'):
        self.data_path = data_path
        self.output_path = output_path
        os.makedirs(output_path, exist_ok=True)
        
    def load_data(self):
        """Load all Olist datasets"""
        logger.info("Loading data...")
        
        self.customers = pd.read_csv(f'{self.data_path}olist_customers_dataset.csv')
        self.orders = pd.read_csv(f'{self.data_path}olist_orders_dataset.csv')
        self.order_items = pd.read_csv(f'{self.data_path}olist_order_items_dataset.csv')
        self.order_payments = pd.read_csv(f'{self.data_path}olist_order_payments_dataset.csv')
        self.products = pd.read_csv(f'{self.data_path}olist_products_dataset.csv')
        self.sellers = pd.read_csv(f'{self.data_path}olist_sellers_dataset.csv')
        self.reviews = pd.read_csv(f'{self.data_path}olist_order_reviews_dataset.csv')
        
        logger.info(f"Loaded {len(self.orders)} orders, {len(self.customers)} customers")
        
    def clean_data(self):
        """Data cleaning operations"""
        logger.info("Cleaning data...")
        
        # Convert date columns
        date_columns = ['order_purchase_timestamp', 'order_approved_at', 
                        'order_delivered_carrier_date', 'order_delivered_customer_date',
                        'order_estimated_delivery_date']
        
        for col in date_columns:
            if col in self.orders.columns:
                self.orders[col] = pd.to_datetime(self.orders[col])
        
        # Handle missing values
        self.products['product_category_name'].fillna('unknown', inplace=True)
        
        # Filter delivered orders only
        self.orders = self.orders[self.orders['order_status'] == 'delivered']
        
        # Remove outliers in payment values
        self.order_payments = self.order_payments[
            self.order_payments['payment_value'] <= self.order_payments['payment_value'].quantile(0.99)
        ]
        
        logger.info("Data cleaning completed")
        
    def create_features(self):
        """Feature engineering"""
        logger.info("Creating features...")
        
        # Merge datasets
        self.data = self.orders.merge(self.order_items, on='order_id', how='left')
        self.data = self.data.merge(self.order_payments, on='order_id', how='left')
        self.data = self.data.merge(self.customers, on='customer_id', how='left')
        self.data = self.data.merge(self.products, on='product_id', how='left')
        
        # Calculate delivery time
        self.data['delivery_time_days'] = (
            self.data['order_delivered_customer_date'] - self.data['order_purchase_timestamp']
        ).dt.days
        
        # Extract temporal features
        self.data['purchase_month'] = self.data['order_purchase_timestamp'].dt.month
        self.data['purchase_year'] = self.data['order_purchase_timestamp'].dt.year
        self.data['purchase_day_of_week'] = self.data['order_purchase_timestamp'].dt.dayofweek
        
        # Calculate profit margin (simplified)
        self.data['estimated_cost'] = self.data['product_weight_g'] * 0.01
        self.data['profit_margin'] = (self.data['price'] - self.data['estimated_cost']) / self.data['price']
        
        # Customer-level aggregates
        customer_agg = self.data.groupby('customer_unique_id').agg({
            'order_id': 'count',
            'payment_value': 'sum',
            'order_purchase_timestamp': ['min', 'max']
        }).reset_index()
        customer_agg.columns = ['customer_unique_id', 'order_count', 'total_spent', 'first_purchase', 'last_purchase']
        customer_agg['recency_days'] = (datetime.now() - customer_agg['last_purchase']).dt.days
        
        self.customer_features = customer_agg
        
        logger.info("Feature engineering completed")
        
    def save_processed_data(self):
        """Save processed data"""
        logger.info("Saving processed data...")
        
        self.data.to_parquet(f'{self.output_path}processed_orders.parquet')
        self.customer_features.to_csv(f'{self.output_path}customer_features.csv', index=False)
        
        logger.info(f"Saved to {self.output_path}")
        
    def run_pipeline(self):
        """Execute full ETL pipeline"""
        start_time = datetime.now()
        logger.info("Starting ETL pipeline...")
        
        self.load_data()
        self.clean_data()
        self.create_features()
        self.save_processed_data()
        
        elapsed = (datetime.now() - start_time).total_seconds()
        logger.info(f"ETL pipeline completed in {elapsed:.2f} seconds")

if __name__ == "__main__":
    etl = EcommerceETL()
    etl.run_pipeline()