-- Revenue Trends Analysis
WITH monthly_revenue AS (
    SELECT 
        DATE_FORMAT(order_purchase_timestamp, '%Y-%m') as month,
        COUNT(DISTINCT o.order_id) as total_orders,
        SUM(payment_value) as total_revenue,
        AVG(payment_value) as avg_order_value
    FROM orders o
    JOIN order_payments op ON o.order_id = op.order_id
    WHERE order_status = 'delivered'
    GROUP BY DATE_FORMAT(order_purchase_timestamp, '%Y-%m')
)
SELECT 
    month,
    total_orders,
    total_revenue,
    avg_order_value,
    LAG(total_revenue) OVER (ORDER BY month) as prev_month_revenue,
    ((total_revenue - LAG(total_revenue) OVER (ORDER BY month)) / 
     LAG(total_revenue) OVER (ORDER BY month)) * 100 as revenue_growth_pct
FROM monthly_revenue;

-- Customer Lifetime Value (CLV)
WITH customer_revenue AS (
    SELECT 
        c.customer_id,
        c.customer_unique_id,
        COUNT(DISTINCT o.order_id) as order_count,
        SUM(payment_value) as total_spent,
        DATEDIFF(MAX(order_purchase_timestamp), MIN(order_purchase_timestamp)) as customer_lifetime_days,
        AVG(payment_value) as avg_order_value
    FROM customers c
    JOIN orders o ON c.customer_id = o.customer_id
    JOIN order_payments op ON o.order_id = op.order_id
    WHERE order_status = 'delivered'
    GROUP BY c.customer_id, c.customer_unique_id
)
SELECT 
    PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY total_spent) as median_clv,
    AVG(total_spent) as avg_clv,
    MAX(total_spent) as max_clv,
    COUNT(CASE WHEN total_spent > 5000 THEN 1 END) as high_value_customers
FROM customer_revenue;

-- Category-level Profit Margins
SELECT 
    p.product_category_name,
    COUNT(DISTINCT o.order_id) as total_orders,
    SUM(price) as total_revenue,
    SUM(payment_value) as total_payment,
    SUM(price - (p.product_weight_g * 0.01)) as estimated_profit,  -- Simplified cost calculation
    (SUM(price - (p.product_weight_g * 0.01)) / SUM(price)) * 100 as profit_margin_pct
FROM products p
JOIN order_items oi ON p.product_id = oi.product_id
JOIN orders o ON oi.order_id = o.order_id
JOIN order_payments op ON o.order_id = op.order_id
WHERE order_status = 'delivered'
GROUP BY p.product_category_name
HAVING total_orders > 100
ORDER BY profit_margin_pct DESC;